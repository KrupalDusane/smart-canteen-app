<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.NmimsCanteenApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
    </style>

    <style name="Theme.NmimsCanteenApp" parent="Base.Theme.NmimsCanteenApp" />

    <style name="RoundedCornerImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="DayButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginHorizontal">4dp</item>
        <item name="android:textColor">@color/grey_icon</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:backgroundTint">#F5F5F5</item>
    </style>
</resources>
