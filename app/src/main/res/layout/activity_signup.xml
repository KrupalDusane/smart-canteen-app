<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/light_bg"
    tools:context=".SignupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. TOP IMAGE BANNER (Same as Login for consistency) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/campus"
                android:contentDescription="@string/campus_banner_desc" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#44000000" />
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/nmims_red" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="-50dp">

            <!-- 2. LOGO -->
            <androidx.cardview.widget.CardView
                android:layout_width="90dp"
                android:layout_height="90dp"
                app:cardCornerRadius="45dp"
                app:cardElevation="10dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/logo"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:contentDescription="@string/app_logo_desc"
                    android:background="@color/white" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register New Account"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_gravity="center"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/campus_name"
                android:textSize="14sp"
                android:textColor="@color/grey_icon"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- 3. SIGNUP CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/signupNameLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Full Name"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/grey_icon"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="@color/nmims_red"
                        app:hintTextColor="@color/grey_icon">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signupNameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="#212121" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/signupSapIdLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/sap_id"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/grey_icon"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="@color/nmims_red"
                        app:hintTextColor="@color/grey_icon">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signupSapIdInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="11"
                            android:textColor="#212121" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/signupPasswordLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/grey_icon"
                        app:passwordToggleEnabled="true"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="24dp"
                        app:boxStrokeColor="@color/nmims_red"
                        app:hintTextColor="@color/grey_icon">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signupPasswordInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="#212121" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/createAccountBtn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Create Account"
                        android:backgroundTint="@color/nmims_red"
                        android:textColor="@android:color/white"
                        app:cornerRadius="28dp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/backToLoginTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:text="Already have an account? Login"
                        android:textColor="@color/nmims_red"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
